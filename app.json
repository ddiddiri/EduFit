{
  "expo": {
    "name": "EduFit",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./shared/assets/images/icon.png",
    "scheme": "edufit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./shared/assets/images/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dino.edufit"
    },
    "android": {
      "package": "com.dino.edufit",
      "adaptiveIcon": {
        "foregroundImage": "./shared/assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./shared/assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e909f17-34e7-4b25-97da-fccd9263fb9f"
      }
    }
  }
}
